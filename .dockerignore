# .dockerignore for the commit-image build.
# Goal: bake in the FULL repo (including .git history — the grader uses it), dropping only local
# build artifacts and editor/OS cruft. Dev image, not minimal. Lands at the fork root (the build
# context). build.sh produces its outputs under /mayhem at build time.

# ── Build outputs / local cruft ──────────────────────────────────────────────
# Cargo build trees (the parent workspace's and the additive fuzz crate's).
/target
target/
mayhem/fuzz/target/
*.o
*.a
*.so
*.dylib
**/__pycache__/

# ── Editor / OS noise ────────────────────────────────────────────────────────
.DS_Store
*.swp
*~
